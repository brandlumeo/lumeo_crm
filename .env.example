# ─────────────────────────────────────────────────────────────────────────────
# Lumeo CRM — Production Environment Variables
# Copy this file to .env and fill in all values before docker compose up.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_python_-c_"import_secrets;print(secrets.token_urlsafe(64))"
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
TIME_ZONE=UTC

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_NAME=lumeo_crm
DB_USER=lumeo
DB_PASSWORD=CHANGE_ME_strong_random_password
DB_HOST=db
DB_PORT=5432

# ── CORS / CSRF ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── JWT ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# ── Pagination ───────────────────────────────────────────────────────────────
API_PAGE_SIZE=20

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Email (Resend SMTP) ───────────────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create Key
# For "from" email: verify your domain in Resend → Domains, then use noreply@yourdomain.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_CHANGE_ME_your_resend_api_key
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
DEFAULT_FROM_EMAIL=Lumeo CRM <noreply@yourdomain.com>

# ── Frontend URL (used in invite & password reset emails) ────────────────────
FRONTEND_URL=https://yourdomain.com

# ── Razorpay (Payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=CHANGE_ME_live_key_id
RAZORPAY_KEY_SECRET=CHANGE_ME_live_key_secret
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_webhook_secret

# ── Gunicorn ─────────────────────────────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_THREADS=2

# ── Next.js (baked at build time via ARG, but keep here as reference) ────────
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
